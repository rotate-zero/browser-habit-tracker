# Copy to .env and fill in your values
# The Bridge API reads this file via python-dotenv

# PostgreSQL connection string
# Since both the Bridge API and PostgreSQL run inside WSL,
# localhost here refers to the WSL instance itself.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/browser_habit_tracker

# CORS origin — keep * for local-only use
# Change to chrome-extension://YOUR_EXTENSION_ID for stricter security
ALLOWED_ORIGIN=*
